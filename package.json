{
  "name": "react-template-cloudappi",
  "version": "1.0.0",
  "author": {
    "name": "Sebastian",
    "email": "sebastian.diaz.pe@cloudappi.net"
  },
  "scripts": {
    "build": "npm run typecheck && vite build",
    "dev": "vite",
    "format": "prettier . --write --ignore-path .gitignore && git update-index --again",
    "lint": "eslint . --ext .ts,.tsx --fix --ignore-path .gitignore",
    "lint:fix": "npm run lint --fix",
    "serve": "npm run build && vite preview --port 3000",
    "sonar:git": "npx sonar-scanner -Dsonar.host.url=$SONAR_HOST_URL -Dsonar.login=$SONAR_TOKEN -Dsonar.projectKey=$SONAR_PROJECT -Dsonar.qualitygate.wait=$SONAR_WAIT_QG",
    "sonar:local:linux": "npx sonar-scanner -Dsonar.host.url=$npm_package_config_sonar_url -Dsonar.login=$npm_package_config_sonar_token -Dsonar.projectKey=$npm_package_config_sonar_project -Dsonar.qualitygate.wait=$npm_package_config_sonar_wait_qg",
    "sonar:local:windows": "npx sonar-scanner -Dsonar.host.url=%npm_package_config_sonar_url% -Dsonar.login=%npm_package_config_sonar_token% -Dsonar.projectKey=%npm_package_config_sonar_project% -Dsonar.qualitygate.wait=%npm_package_config_sonar_wait_qg%",
    "test:e2e": "start-server-and-test serve http://127.0.0.1:3000/ 'cypress open'",
    "test:e2e:ci": "start-server-and-test serve http://127.0.0.1:3000/ 'cypress run'",
    "test:sonar": "npm run test:unit-with-coverage && npm run sonar:git",
    "test:sonar:local:linux": "npm run test:unit-with-coverage && npm run sonar:local:linux",
    "test:sonar:local:windows": "npm run test:unit-with-coverage && npm run sonar:local:windows",
    "test:unit": "jest --watch",
    "test:unit-with-coverage": "jest --silent --watchAll=false --coverage --passWithNoTests",
    "test:unit:ci": "jest",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{css,md,json}": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "npm run lint"
    ],
    "package.json": "npx sort-package-json"
  },
  "config": {
    "sonar_project": "templates-front-reacttoken",
    "sonar_token": "9ecd7d6f1d7c2c633bfe5d891880a54270b8066d",
    "sonar_url": "https://sonarqube.cloudappi.net/",
    "sonar_wait_qg": "true"
  },
  "overrides": {
    "rollup": ">=2.78.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@gaia-x/json-web-signature-2020": "^2.3.0",
    "@microlink/react-json-view": "^1.27.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@reduxjs/toolkit": "^1.9.5",
    "axios": "^1.2.2",
    "i18n": "^0.15.3",
    "i18next-http-backend": "^3.0.2",
    "jose": "^6.2.2",
    "jwt-decode": "^3.1.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.5.0",
    "react-redux": "^8.0.5",
    "react-router-dom": "^6.11.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.0.2",
    "@commitlint/config-conventional": "^17.0.2",
    "@cypress/vite-dev-server": "^3.0.0",
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.3.0",
    "@testing-library/user-event": "^14.2.1",
    "@types/jest": "^28.1.3",
    "@types/jsonld": "^1.5.15",
    "@types/node": "^18.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/testing-library__user-event": "^4.2.0",
    "@typescript-eslint/eslint-plugin": "^5.29.0",
    "@typescript-eslint/parser": "^5.29.0",
    "@vitejs/plugin-legacy": "^1.8.2",
    "@vitejs/plugin-react": "^1.3.2",
    "cypress": "^15.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.18.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-import-resolver-typescript": "^2.7.1",
    "eslint-plugin-cypress": "^2.12.1",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jest": "^26.5.3",
    "eslint-plugin-jest-dom": "^4.0.2",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.30.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "eslint-plugin-testing-library": "^5.5.1",
    "husky": "^8.0.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^28.1.1",
    "jest-environment-jsdom": "^28.1.1",
    "lint-staged": "^13.0.2",
    "prettier": "^2.7.1",
    "sass": "^1.57.1",
    "sonar-scanner": "^3.1.0",
    "sort-package-json": "^1.57.0",
    "start-server-and-test": "^2.0.0",
    "ts-jest": "^28.0.5",
    "typescript": "^5.9.3",
    "vite": "^2.9.12",
    "vite-plugin-node-polyfills": "^0.25.0"
  }
}
